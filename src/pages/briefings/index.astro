---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('briefings'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<BaseLayout title="Signal Briefings" description="Dense daily intelligence briefings with the most important developments.">
  <div class="mx-auto max-w-[var(--spacing-site)] px-4 py-12 sm:px-6">
    <div class="mb-8">
      <h1 class="mb-2" style="font-size: var(--text-3xl);">Signal Briefings</h1>
      <p class="text-muted">Dense daily intelligence briefings with the most important developments.</p>
    </div>

    {entries.length > 0 ? (
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {entries.map((entry) => (
          <ArticleCard
            title={entry.data.title}
            description={entry.data.description}
            publishDate={entry.data.publishDate}
            slug={entry.id}
            collection="briefings"
          />
        ))}
      </div>
    ) : (
      <p class="text-center py-16 text-muted">No briefings yet. Check back soon.</p>
    )}
  </div>
</BaseLayout>
