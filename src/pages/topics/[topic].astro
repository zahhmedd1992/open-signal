---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

type CollectionName = 'deep-signals' | 'briefings' | 'signal-maps' | 'long-view' | 'open-source';

export const getStaticPaths: GetStaticPaths = async () => {
  const deepSignals = await getCollection('deep-signals');
  const briefings = await getCollection('briefings');
  const signalMaps = await getCollection('signal-maps');
  const longView = await getCollection('long-view');
  const openSource = await getCollection('open-source');

  const allEntries = [
    ...deepSignals.map((e) => ({ ...e, collection: 'deep-signals' as CollectionName })),
    ...briefings.map((e) => ({ ...e, collection: 'briefings' as CollectionName })),
    ...signalMaps.map((e) => ({ ...e, collection: 'signal-maps' as CollectionName })),
    ...longView.map((e) => ({ ...e, collection: 'long-view' as CollectionName })),
    ...openSource.map((e) => ({ ...e, collection: 'open-source' as CollectionName })),
  ];

  const tagMap = new Map<string, typeof allEntries>();

  for (const entry of allEntries) {
    const tags = entry.data.tags ?? [];
    for (const tag of tags) {
      if (!tagMap.has(tag)) {
        tagMap.set(tag, []);
      }
      tagMap.get(tag)!.push(entry);
    }
  }

  return Array.from(tagMap.entries()).map(([topic, articles]) => ({
    params: { topic },
    props: {
      topic,
      articles: articles.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()),
    },
  }));
};

interface Props {
  topic: string;
  articles: Array<{
    id: string;
    collection: CollectionName;
    data: {
      title: string;
      description: string;
      publishDate: Date;
      tags?: string[];
      featured?: boolean;
    };
  }>;
}

const { topic, articles } = Astro.props;
---

<BaseLayout title={`Topic: ${topic}`} description={`All Open Signal articles tagged "${topic}".`}>
  <div class="mx-auto max-w-[var(--spacing-site)] px-4 py-12 sm:px-6">
    <div class="mb-8">
      <p class="font-sans text-sm uppercase tracking-widest font-medium mb-2" style="color: var(--color-accent);">Topic</p>
      <h1 class="mb-2" style="font-size: var(--text-3xl);">{topic}</h1>
      <p class="text-muted">{articles.length} article{articles.length !== 1 ? 's' : ''}</p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {articles.map((entry) => (
        <ArticleCard
          title={entry.data.title}
          description={entry.data.description}
          publishDate={entry.data.publishDate}
          slug={entry.id}
          collection={entry.collection}
        />
      ))}
    </div>
  </div>
</BaseLayout>
