---
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;

const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(url);
const twitterUrl = `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`;
const linkedinUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`;
---

<div class="flex items-center gap-2" data-share-buttons>
  <!-- Copy link -->
  <button
    type="button"
    class="share-btn inline-flex items-center justify-center rounded-md p-2 transition-colors"
    style="color: var(--color-muted);"
    aria-label="Copy link to clipboard"
    data-share-copy
    data-url={url}
  >
    <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.86-2.846a4.5 4.5 0 00-1.242-7.244l-4.5-4.5a4.5 4.5 0 00-6.364 6.364L4.343 8.17" />
    </svg>
    <!-- Checkmark shown after copy -->
    <svg class="copy-confirm hidden h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="color: var(--color-success);">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
    </svg>
  </button>

  <!-- Twitter/X -->
  <a
    href={twitterUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="share-btn inline-flex items-center justify-center rounded-md p-2 no-underline transition-colors"
    style="color: var(--color-muted);"
    aria-label="Share on X (Twitter)"
  >
    <svg class="h-4.5 w-4.5" viewBox="0 0 24 24" fill="currentColor">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
    </svg>
  </a>

  <!-- LinkedIn -->
  <a
    href={linkedinUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="share-btn inline-flex items-center justify-center rounded-md p-2 no-underline transition-colors"
    style="color: var(--color-muted);"
    aria-label="Share on LinkedIn"
  >
    <svg class="h-4.5 w-4.5" viewBox="0 0 24 24" fill="currentColor">
      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
    </svg>
  </a>
</div>

<style>
  .share-btn:hover {
    color: var(--color-text) !important;
    background-color: var(--color-surface);
  }
  .dark .share-btn:hover {
    color: var(--color-text-dark) !important;
    background-color: var(--color-surface-dark);
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const copyBtns = document.querySelectorAll("[data-share-copy]");

    copyBtns.forEach((btn) => {
      btn.addEventListener("click", async () => {
        const url = btn.getAttribute("data-url") || window.location.href;
        const linkIcon = btn.querySelector("svg:first-child");
        const confirmIcon = btn.querySelector(".copy-confirm");

        try {
          await navigator.clipboard.writeText(url);
          linkIcon?.classList.add("hidden");
          confirmIcon?.classList.remove("hidden");

          setTimeout(() => {
            linkIcon?.classList.remove("hidden");
            confirmIcon?.classList.add("hidden");
          }, 2000);
        } catch {
          /* Fallback: select text in a temporary input */
          const input = document.createElement("input");
          input.value = url;
          document.body.appendChild(input);
          input.select();
          document.execCommand("copy");
          document.body.removeChild(input);
        }
      });
    });
  });
</script>
